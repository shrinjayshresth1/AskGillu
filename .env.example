GROQ_API_KEY=your_groq_api_key_here

# Vector Database Configuration
DEFAULT_DB_TYPE=qdrant
QDRANT_URL=your_qdrant_url_here
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_NAME=askgillu_documents
FAISS_INDEX_PATH=./vectorstore/db_faiss

# Advanced RAG Features Configuration
# Semantic Chunking
ENABLE_SEMANTIC_CHUNKING=true
SEMANTIC_CHUNK_SIZE=1000
SEMANTIC_CHUNK_OVERLAP=200

# Advanced Re-ranking
ENABLE_RERANKING=true
RERANKING_STRATEGY=rrf
RERANK_TOP_K=10
FINAL_TOP_K=5

# Response Caching
ENABLE_RESPONSE_CACHING=true
CACHE_SIMILARITY_THRESHOLD=0.85
CACHE_TTL_HOURS=24
MAX_CACHE_SIZE=1000

# Feedback Loop
ENABLE_FEEDBACK_TRACKING=true
FEEDBACK_WEIGHT=0.1
MIN_FEEDBACK_THRESHOLD=3

# Performance Monitoring
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_LOG_INTERVAL=100
SLOW_QUERY_THRESHOLD_MS=5000
